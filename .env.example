# OpenAI API Key (required for resume parsing + insight generation)
OPENAI_API_KEY=sk-your-openai-api-key

# RapidAPI Key (required for JSearch job data)
RAPIDAPI_KEY=your-rapidapi-key

# Razorpay (optional - for payment integration)
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Supabase Configuration (required for authentication and database)
# Get these from your Supabase project settings: https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OAuth Configuration (configured in Supabase Auth providers)
# These are optional - OAuth is configured in Supabase dashboard
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id
# NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-oauth-app-id
